{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://wany-kb/harness-builder/process.schema.json",
  "title": "HarnessProcess",
  "description": "Opinionated schema for a business process that compiles into an NLAH (Natural Language Agent Harness) markdown spec.",
  "type": "object",
  "required": ["process_name", "version", "description", "owner", "steps"],
  "additionalProperties": false,
  "properties": {
    "process_name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "Kebab-case identifier. Used as the harness id."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": { "type": "string", "minLength": 10 },
    "owner": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "team": { "type": "string" },
        "contact": { "type": "string" }
      }
    },
    "trigger": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "enum": ["manual", "webhook", "schedule", "event"] },
        "cron": { "type": "string" },
        "event": { "type": "string" },
        "source": { "type": "string" }
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "type": { "enum": ["string", "number", "boolean", "object", "array", "url", "email", "file"] },
          "required": { "type": "boolean", "default": true },
          "description": { "type": "string" },
          "example": {}
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "description"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
          "description": { "type": "string" },
          "type": { "enum": ["agent", "tool", "llm", "decision"] },
          "agent": { "type": "string" },
          "tool": { "type": "string" },
          "prompt": { "type": "string" },
          "model": { "type": "string" },
          "timeout_ms": { "type": "integer", "minimum": 100 },
          "retries": { "type": "integer", "minimum": 0, "maximum": 10 },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          },
          "outputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "branches": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    },
    "human_checkpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["after_step", "prompt"],
        "additionalProperties": false,
        "properties": {
          "after_step": { "type": "string" },
          "prompt": { "type": "string" },
          "required": { "type": "boolean", "default": true },
          "expected_input": {
            "type": "string",
            "description": "What the human is expected to provide: approval, text, choice, etc."
          },
          "sla_minutes": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "description": { "type": "string" },
          "sink": { "type": "string", "description": "Where the output is written: slack, crm, s3, ..." }
        }
      }
    },
    "error_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "retry": { "type": "integer", "minimum": 0, "maximum": 10 },
        "backoff": { "enum": ["none", "linear", "exponential"] },
        "fallback_agent": { "type": "string" },
        "on_failure": { "enum": ["halt", "skip", "human_escalate"] }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
